# Konfigurasi AWS S3
S3_BUCKET_NAME=name-bucket-

# Kredensial AWS
# HANYA untuk development lokal. Di EC2 biarkan kosong dan gunakan IAM role --
# kredensial statis di file justru menimpa role dan menyulitkan debugging.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Wajib saat lokal. Di EC2 boto3 mengambilnya dari instance metadata.
AWS_DEFAULT_REGION=us-east-1

# Konfigurasi Flask Server
# Lokal gunakan 127.0.0.1, di EC2 gunakan 0.0.0.0
FLASK_PORT=5000
FLASK_HOST=0.0.0.0

# Konfigurasi Keamanan (CORS)
# Saat development gunakan '*', saat production ganti dengan URL AWS Amplify-mu
CORS_ORIGIN=*